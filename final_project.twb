    <worksheet name='Reset Button'>
      <table>
        <view>
          <datasources>
            <datasource caption='Final Data (Data Preprocessing)' name='federated.0n3bkut0qukr4r1ex8rcf0nnkjs7' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Month' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Dec-2009&quot;'>
              <calculation class='tableau' formula='&quot;Dec-2009&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0n3bkut0qukr4r1ex8rcf0nnkjs7'>
            <column caption='Positive % Diff Arrow' datatype='string' name='[Calculation_1270761208938496]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1270761209237505]&gt; 0&#13;&#10;THEN &apos;⤤&apos;&#13;&#10;END' />
            </column>
            <column caption='MOM Revenue Growth' datatype='real' default-format='p0.0%' name='[Calculation_1270761209237505]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(ZN([Calculation_1338106180550656]) - ZN([Calculation_1338106188439553])) / ZN([Calculation_1338106188439553])' />
            </column>
            <column caption='Negative % Diff Arrow' datatype='string' name='[Calculation_1270761209860098]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1270761209237505]&lt;0&#13;&#10;THEN &apos;⤥&apos;&#13;&#10;END' />
            </column>
            <column caption='KPI Color Rule' datatype='string' name='[Calculation_1270761210146819]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1338106180550656] &gt; [Calculation_1338106188439553] THEN &quot;Positive&quot;&#13;&#10;ELSEIF [Calculation_1338106180550656] &lt; [Calculation_1338106188439553] THEN &quot;Negative&quot;&#13;&#10;ELSE &quot;Neutral&quot;&#13;&#10;END' />
            </column>
            <column caption='CurrentMonth Sales' datatype='real' name='[Calculation_1338106180550656]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ SUM(IF [Month-Year] = [Parameters].[Parameter 1] THEN [Net Sales] END) }' />
            </column>
            <column caption='PreviousMonth Sales' datatype='real' name='[Calculation_1338106188439553]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ SUM(IF [Month-Year] = LEFT(DATENAME(&apos;month&apos;, DATEADD(&apos;month&apos;, -1, DATEPARSE(&apos;MMM-yyyy&apos;, [Parameters].[Parameter 1]))), 3) + &quot;-&quot; + STR(YEAR(DATEADD(&apos;month&apos;, -1, DATEPARSE(&apos;MMM-yyyy&apos;, [Parameters].[Parameter 1])))) THEN [Net Sales] END) }' />
            </column>
            <column caption='Reset Button' datatype='string' name='[Calculation_1751248222216192]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&apos;Reset All Filters&apos;' />
            </column>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal'>
              <aliases>
                <alias key='&quot;EIRE&quot;' value='Ireland' />
                <alias key='&quot;Israel&quot;' value='Palestine' />
                <alias key='&quot;RSA&quot;' value='South Africa' />
                <alias key='&quot;USA&quot;' value='United States' />
              </aliases>
            </column>
            <column datatype='string' name='[Customer Segment]' role='dimension' type='nominal' />
            <column datatype='string' name='[Description]' role='dimension' type='nominal' />
            <column datatype='string' name='[Month-Year]' role='dimension' type='nominal' />
