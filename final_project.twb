    <worksheet name='RepeatPurchaseRate'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#ffffff' fontname='Tableau Book' fontsize='14'>Repeat Purchase</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Final Data (Data Preprocessing)' name='federated.0n3bkut0qukr4r1ex8rcf0nnkjs7' />
          </datasources>
          <datasource-dependencies datasource='federated.0n3bkut0qukr4r1ex8rcf0nnkjs7'>
            <column caption='RepeatPurchaseRateCalculated' datatype='real' name='[Calculation_1107546655293449]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sUM(&#13;&#10;    IF [Calculation_1172631106351104] = &quot;Repeat&quot; THEN 1 ELSE 0 END&#13;&#10;) / COUNTD([Customer ID])' />
            </column>
            <column caption='RepeatPurchase1ST Field' datatype='string' name='[Calculation_1172631106351104]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF { FIXED [Customer ID] : COUNTD([Month-Year]) } &gt; 1 &#13;&#10;THEN &quot;Repeat&quot; &#13;&#10;ELSE &quot;One-time&quot; &#13;&#10;END' />
            </column>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal'>
              <aliases>
                <alias key='&quot;EIRE&quot;' value='Ireland' />
                <alias key='&quot;Israel&quot;' value='Palestine' />
                <alias key='&quot;RSA&quot;' value='South Africa' />
                <alias key='&quot;USA&quot;' value='United States' />
              </aliases>
            </column>
            <column datatype='string' name='[Customer ID]' role='dimension' type='nominal' />
