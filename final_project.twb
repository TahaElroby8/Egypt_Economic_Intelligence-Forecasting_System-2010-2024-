            <column-instance column='[Calculation_1270761210146819]' derivation='None' name='[none:Calculation_1270761210146819:nk]' pivot='key' type='nominal' />
            <column-instance column='[Customer Segment]' derivation='None' name='[none:Customer Segment:nk]' pivot='key' type='nominal' />
