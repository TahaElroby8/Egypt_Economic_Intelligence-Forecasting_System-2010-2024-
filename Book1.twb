              <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, {FIXED [Customer ID] : MAX([InvoiceDate])}, {MAX([InvoiceDate])})' />
            </column>
            <column caption='Churn Risk Status' datatype='string' name='[Calculation_2445381821022210]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_2445381820887041] &lt;= 1 THEN &quot;Active&quot;&#13;&#10;ELSEIF [Calculation_2445381820887041] &lt;= 3 THEN &quot;Slipping&quot;&#13;&#10;ELSEIF [Calculation_2445381820887041] &lt;= 6 THEN &quot;At Risk&quot;&#13;&#10;ELSE &quot;Churned&quot;&#13;&#10;END' />
            </column>
