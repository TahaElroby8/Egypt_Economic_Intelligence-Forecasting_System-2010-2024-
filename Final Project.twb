      <aliases enabled='yes' />
      <column aggregation='None' datatype='integer' name='[Average Order Value (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='2' formula='[Average Order Value]' peg='0' size='202' />
      </column>
      <column datatype='real' name='[Average Order Value]' role='measure' type='quantitative' />
      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Customer Segment]) / TOTAL(COUNT([Customer Segment]))'>
          <table-calc ordering-field='[federated.0n3bkut0qukr4r1ex8rcf0nnkjs7].[none:Customer Segment:nk]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='RateOfReturn' datatype='real' name='[Calculation_0671866993819648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(311700/8721196)' />
      </column>
      <column caption='TotalOrdersCalculated' datatype='integer' name='[Calculation_1107546645929984]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Invoice])' />
      </column>
      <column caption='RepeatPurchaseRateCalculated' datatype='real' name='[Calculation_1107546655293449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF { FIXED [Customer ID] : COUNTD([Invoice]) } &gt; 1 &#13;&#10;    THEN 1 &#13;&#10;    ELSE 0 &#13;&#10;    END&#13;&#10;) / COUNTD([Customer ID])' />
      </column>
      <column caption='Positive % Diff Arrow' datatype='string' name='[Calculation_1270761208938496]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1270761209237505]&gt; 0&#13;&#10;THEN &apos;⤤&apos;&#13;&#10;END' />
      </column>
      <column caption='MOM Revenue Growth' datatype='real' default-format='p0.0%' name='[Calculation_1270761209237505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN([Calculation_1338106180550656]) - ZN([Calculation_1338106188439553])) / ZN([Calculation_1338106188439553])' />
      </column>
      <column caption='Negative % Diff Arrow' datatype='string' name='[Calculation_1270761209860098]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1270761209237505]&lt;0&#13;&#10;THEN &apos;⤥&apos;&#13;&#10;END' />
      </column>
      <column caption='KPI Color Rule' datatype='string' name='[Calculation_1270761210146819]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1338106180550656] &gt; [Calculation_1338106188439553] THEN &quot;Positive&quot;&#13;&#10;ELSEIF [Calculation_1338106180550656] &lt; [Calculation_1338106188439553] THEN &quot;Negative&quot;&#13;&#10;ELSE &quot;Neutral&quot;&#13;&#10;END' />
      </column>
      <column caption='CurrentMonth Sales' datatype='real' name='[Calculation_1338106180550656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ SUM(IF [Month-Year] = [Parameters].[Parameter 1] THEN [Net Sales] END) }' />
      </column>
      <column caption='PreviousMonth Sales' datatype='real' name='[Calculation_1338106188439553]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ SUM(IF [Month-Year] = LEFT(DATENAME(&apos;month&apos;, DATEADD(&apos;month&apos;, -1, DATEPARSE(&apos;MMM-yyyy&apos;, [Parameters].[Parameter 1]))), 3) + &quot;-&quot; + STR(YEAR(DATEADD(&apos;month&apos;, -1, DATEPARSE(&apos;MMM-yyyy&apos;, [Parameters].[Parameter 1])))) THEN [Net Sales] END) }' />
      </column>
      <column caption='Reset Button' datatype='string' name='[Calculation_1751248222216192]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;Reset All Filters&apos;' />
      </column>
      <column caption='Sales Value' datatype='real' name='[Calculation_2147414138949632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Quantity] &gt; 0 &#13;&#10;THEN [Net Sales] &#13;&#10;END' />
      </column>
      <column caption='Latest Customer Date' datatype='datetime' name='[Calculation_2445381820690432]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [Customer ID] : MAX([InvoiceDate]) }' />
      </column>
      <column aggregation='Sum' caption='Months Since Purchase' datatype='integer' name='[Calculation_2445381820887041]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, {FIXED [Customer ID] : MAX([InvoiceDate])}, {MAX([InvoiceDate])})' />
      </column>
      <column caption='Churn Risk Status' datatype='string' name='[Calculation_2445381821022210]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2445381820887041] &lt;= 1 THEN &quot;Active&quot;&#13;&#10;ELSEIF [Calculation_2445381820887041] &lt;= 3 THEN &quot;Slipping&quot;&#13;&#10;ELSEIF [Calculation_2445381820887041] &lt;= 6 THEN &quot;At Risk&quot;&#13;&#10;ELSE &quot;Churned&quot;&#13;&#10;END' />
